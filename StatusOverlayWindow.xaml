<Window x:Class="LegendaryCSharp.StatusOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Width="240"
        Height="72">
    <Border Background="#E61F2A2E"
            BorderBrush="#F7F0E2"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Ellipse x:Name="StateDot"
                     Width="18"
                     Height="18"
                     Fill="#43A047"
                     VerticalAlignment="Center"
                     Margin="0,0,12,0" />
            <StackPanel Grid.Column="1">
                <TextBlock x:Name="TitleText"
                           Text="状态"
                           Foreground="#F7F0E2"
                           FontSize="15"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="DetailText"
                           Text="已更新"
                           Foreground="#C8D6CF"
                           FontSize="12"
                           Margin="0,3,0,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

<Window x:Class="LegendaryCSharp.KeyPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择按键"
        Width="780"
        Height="520"
        MinWidth="720"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#F4F1EA">
    <Window.Resources>
        <Style x:Key="KeyButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Background" Value="#FFFDF8" />
            <Setter Property="BorderBrush" Value="#B9B0A1" />
            <Setter Property="Foreground" Value="#263238" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Background="#1F2A2E" CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="TitleText"
                               Text="选择按键"
                               Foreground="#F7F0E2"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock x:Name="HintText"
                               Text="点一个键"
                               Foreground="#C8D6CF"
                               Margin="0,5,0,0" />
                </StackPanel>
                <Border Grid.Column="1"
                        BorderBrush="#C8D6CF"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="12,6"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="CurrentKeyText"
                               Text="当前："
                               Foreground="#F7F0E2"
                               FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="键盘"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#263238"
                               Margin="0,0,0,8" />
                    <UniformGrid x:Name="FunctionKeyPanel" Rows="1" Columns="13" />
                    <UniformGrid x:Name="NumberKeyPanel" Rows="1" Columns="10" Margin="0,8,0,0" />
                    <UniformGrid x:Name="TopLetterPanel" Rows="1" Columns="10" Margin="24,8,0,0" />
                    <UniformGrid x:Name="HomeLetterPanel" Rows="1" Columns="9" Margin="44,8,46,0" />
                    <UniformGrid x:Name="BottomLetterPanel" Rows="1" Columns="7" Margin="72,8,90,0" />
                    <UniformGrid x:Name="ModifierKeyPanel" Rows="1" Columns="8" Margin="0,12,0,0" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <GroupBox Header="方向 / 编辑" Padding="10">
                            <UniformGrid x:Name="NavigationKeyPanel" Rows="3" Columns="4" />
                        </GroupBox>

                        <GroupBox Grid.Column="2" Header="小键盘" Padding="10">
                            <UniformGrid x:Name="NumPadPanel" Rows="2" Columns="5" />
                        </GroupBox>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="鼠标"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#263238"
                               Margin="0,0,0,8" />
                    <UniformGrid x:Name="MouseKeyPanel" Rows="5" Columns="1" />
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="取消"
                    Width="84"
                    Height="32"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>

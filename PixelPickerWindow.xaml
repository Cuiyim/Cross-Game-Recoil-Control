<Window x:Class="LegendaryCSharp.PixelPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="Transparent"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseMove="Window_MouseMove">
    <Canvas x:Name="RootCanvas">
        <Image x:Name="ScreenImage" Stretch="Fill" />
        <Border x:Name="LoupeBorder"
                Width="192"
                Height="224"
                Background="#F9F6EF"
                BorderBrush="#1F2A2E"
                BorderThickness="2"
                CornerRadius="8"
                Padding="8">
            <StackPanel>
                <TextBlock x:Name="PixelInfoText"
                           Text="移动鼠标取色"
                           Foreground="#1F2A2E"
                           FontSize="12"
                           Margin="0,0,0,6" />
                <Border BorderBrush="#5F6F68" BorderThickness="1" Background="#FFFFFF">
                    <Canvas x:Name="LoupeCanvas" Width="168" Height="168" ClipToBounds="True">
                        <Image x:Name="LoupeImage"
                               Width="168"
                               Height="168"
                               Stretch="Fill"
                               RenderOptions.BitmapScalingMode="NearestNeighbor" />
                        <Rectangle x:Name="TargetPixelRectangle"
                                   Width="8"
                                   Height="8"
                                   Fill="#33D32F2F"
                                   Stroke="#D32F2F"
                                   StrokeThickness="1"
                                   Canvas.Left="80"
                                   Canvas.Top="80" />
                    </Canvas>
                </Border>
                <TextBlock Text="红框内为目标像素，左键确认，Esc 取消"
                           Foreground="#66736F"
                           FontSize="12"
                           Margin="0,6,0,0" />
            </StackPanel>
        </Border>
    </Canvas>
</Window>

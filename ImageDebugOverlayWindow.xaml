<Window x:Class="LegendaryCSharp.ImageDebugOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent"
        Width="330"
        Height="118">
    <Border Background="#D91B1F23"
            BorderBrush="#607D8B"
            BorderThickness="1"
            CornerRadius="8"
            Padding="12">
        <StackPanel>
            <TextBlock Text="识别调试"
                       Foreground="#F7F0E2"
                       FontWeight="SemiBold"
                       FontSize="14" />
            <TextBlock x:Name="StateText"
                       Text="未启动"
                       Foreground="#C8D6CF"
                       FontSize="12"
                       Margin="0,6,0,0" />
            <TextBlock x:Name="DetailText"
                       Text="等待扫描"
                       Foreground="#C8D6CF"
                       FontSize="12"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
            <TextBlock x:Name="TimeText"
                       Text=""
                       Foreground="#90A4AE"
                       FontSize="11"
                       Margin="0,4,0,0" />
        </StackPanel>
    </Border>
</Window>

<Window x:Class="LegendaryCSharp.UsageInstructionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="使用说明 v3.1.5"
        Icon="Assets/app.ico"
        Width="680"
        Height="620"
        MinWidth="520"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="#F2F2F7">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="使用说明 v3.1.5"
                   FontSize="26"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource LabelBrush}"
                   Margin="0,0,0,14" />

        <Border Grid.Row="1"
                BorderBrush="{StaticResource SeparatorBrush}"
                BorderThickness="1"
                Background="{StaticResource CardBgBrush}"
                CornerRadius="12">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="14">
                <TextBlock x:Name="UsageText"
                           TextWrapping="Wrap"
                           FontSize="14"
                           LineHeight="23"
                           Foreground="{StaticResource LabelBrush}" />
            </ScrollViewer>
        </Border>

        <Button Grid.Row="2"
                Content="关闭"
                Width="88"
                Height="34"
                Margin="0,14,0,0"
                HorizontalAlignment="Right"
                Click="CloseButton_Click" />
    </Grid>
</Window>
